      "source": [
        "import os\n",
        "import random\n",
        "import numpy as np\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.nn.functional as F\n",
        "from torch.utils.data import DataLoader, Dataset\n",
        "from torchvision import transforms, datasets\n",
        "from tqdm import tqdm\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "\n",
        "BATCH_SIZE = 64\n",
        "EPOCHS = 7\n",
        "LEARNING_RATE = 1e-3\n",
        "IMAGE_SIZE = 224\n",
        "DEVICE = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "\n",
        "print(f\"Używane urządzenie: {DEVICE}\")\n",
        "\n",
        "# Dynamiczne ustalanie ścieżki do danych\n",
        "BASE_DATA_DIR = \"/content/gtsrb_dataset/Train/Train\"\n",
        "if not os.path.exists(BASE_DATA_DIR) and os.path.exists(\"/content/gtsrb_dataset/Train/Train\"):\n",
        "    BASE_DATA_DIR = \"/content/gtsrb_dataset/Train/Train\"\n",
        "\n",
        "print(f\"Ścieżka do danych: {BASE_DATA_DIR}\")\n",
        "\n",
        "train_transforms = transforms.Compose([\n",
        "    transforms.Resize((IMAGE_SIZE, IMAGE_SIZE)),\n",
        "    transforms.RandomRotation(degrees=10),\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n",
        "])\n",
        "\n",
        "val_transforms = transforms.Compose([\n",
        "    transforms.Resize((IMAGE_SIZE, IMAGE_SIZE)),\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n",
        "])\n",
        "\n",
        "# Klasa naprawiająca Data Leakage w random_split\n",
        "class TransformedSubset(Dataset):\n",
        "    def __init__(self, subset, transform=None):\n",
        "        self.subset = subset\n",
        "        self.transform = transform\n",
        "\n",
        "    def __getitem__(self, index):\n",
        "        x, y = self.subset[index]\n",
        "        if self.transform:\n",
        "            x = self.transform(x)\n",
        "        return x, y\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.subset)\n",
        "\n",
        "# Wczytanie danych\n",
        "full_dataset = datasets.ImageFolder(root=BASE_DATA_DIR)\n",
        "class_names = full_dataset.classes\n",
        "num_classes = len(class_names)\n",
        "print(f\"Liczba wykrytych klas: {num_classes}\")\n",
        "\n",
        "# Podział danych (80% trening, 20% walidacja)\n",
        "train_size = int(0.8 * len(full_dataset))\n",
        "val_size = len(full_dataset) - train_size\n",
        "torch.manual_seed(42)\n",
        "train_sub, val_sub = torch.utils.data.random_split(full_dataset, [train_size, val_size])\n",
        "\n",
        "# Bezpieczne nałożenie transformacji\n",
        "train_dataset = TransformedSubset(train_sub, transform=train_transforms)\n",
        "val_dataset = TransformedSubset(val_sub, transform=val_transforms)\n",
        "\n",
        "train_loader = DataLoader(train_dataset, batch_size=BATCH_SIZE, shuffle=True, num_workers=2)\n",
        "val_loader = DataLoader(val_dataset, batch_size=BATCH_SIZE, shuffle=False, num_workers=2)\n",
        "\n",
        "\n",
        "class SimpleTrafficSignCNN(nn.Module):\n",
        "    def __init__(self, num_classes):\n",
        "        super(SimpleTrafficSignCNN, self).__init__()\n",
        "        self.conv1 = nn.Conv2d(3, 16, kernel_size=3, padding=1)\n",
        "        self.bn1 = nn.BatchNorm2d(16)\n",
        "        self.conv2 = nn.Conv2d(16, 32, kernel_size=3, padding=1)\n",
        "        self.bn2 = nn.BatchNorm2d(32)\n",
        "        self.conv3 = nn.Conv2d(32, 64, kernel_size=3, padding=1)\n",
        "        self.bn3 = nn.BatchNorm2d(64)\n",
        "        self.pool = nn.MaxPool2d(2, 2)\n",
        "        self.fc1 = nn.Linear(64 * 28 * 28, 128)\n",
        "        self.fc2 = nn.Linear(128, num_classes)\n",
        "\n",
        "    def forward(self, x):\n",
        "        x = self.pool(F.relu(self.bn1(self.conv1(x))))\n",
        "        x = self.pool(F.relu(self.bn2(self.conv2(x))))\n",
        "        x = self.pool(F.relu(self.bn3(self.conv3(x))))\n",
        "        x = x.view(x.size(0), -1)\n",
        "        x = F.relu(self.fc1(x))\n",
        "        x = self.fc2(x)\n",
        "        return x\n",
        "\n",
        "model = SimpleTrafficSignCNN(num_classes=num_classes).to(DEVICE)\n",
        "criterion = nn.CrossEntropyLoss()\n",
        "optimizer = torch.optim.Adam(model.parameters(), lr=LEARNING_RATE)\n",
        "\n",
        "# Słowniki do zbierania statystyk na wykres\n",
        "history = {'train_acc': [], 'val_acc': [], 'train_loss': [], 'val_loss': []}\n",
        "\n",
        "\n",
        "for epoch in range(EPOCHS):\n",
        "    # TRENING\n",
        "    model.train()\n",
        "    running_loss = 0.0\n",
        "    correct_train = 0\n",
        "    total_train = 0\n",
        "\n",
        "    pbar = tqdm(train_loader, desc=f\"Epoka {epoch+1}/{EPOCHS} [Trening]\")\n",
        "    for images, labels in pbar:\n",
        "        images, labels = images.to(DEVICE), labels.to(DEVICE)\n",
        "\n",
        "        optimizer.zero_grad()\n",
        "        outputs = model(images)\n",
        "        loss = criterion(outputs, labels)\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "\n",
        "        running_loss += loss.item() * images.size(0)\n",
        "        _, predicted = outputs.max(1)\n",
        "        total_train += labels.size(0)\n",
        "        correct_train += predicted.eq(labels).sum().item()\n",
        "\n",
        "        pbar.set_postfix({'loss': loss.item()})\n",
        "\n",
        "    epoch_train_loss = running_loss / len(train_sub)\n",
        "    epoch_train_acc = 100. * correct_train / total_train\n",
        "\n",
        "    # WALIDACJA\n",
        "    model.eval()\n",
        "    val_loss = 0.0\n",
        "    correct_val = 0\n",
        "    total_val = 0\n",
        "\n",
        "    with torch.no_grad():\n",
        "        for images, labels in val_loader:\n",
        "            images, labels = images.to(DEVICE), labels.to(DEVICE)\n",
        "            outputs = model(images)\n",
        "            loss = criterion(outputs, labels)\n",
        "\n",
        "            val_loss += loss.item() * images.size(0)\n",
        "            _, predicted = outputs.max(1)\n",
        "            total_val += labels.size(0)\n",
        "            correct_val += predicted.eq(labels).sum().item()\n",
        "\n",
        "    epoch_val_loss = val_loss / len(val_sub)\n",
        "    epoch_val_acc = 100. * correct_val / total_val\n",
        "\n",
        "    # Zapis historii do wykresu\n",
        "    history['train_acc'].append(epoch_train_acc)\n",
        "    history['val_acc'].append(epoch_val_acc)\n",
        "    history['train_loss'].append(epoch_train_loss)\n",
        "    history['val_loss'].append(epoch_val_loss)\n",
        "\n",
        "    print(f\"\\n Podsumowanie Epoki {epoch+1}:\")\n",
        "    print(f\"  [Trening] Loss: {epoch_train_loss:.4f} | Skuteczność: {epoch_train_acc:.2f}%\")\n",
        "    print(f\"  [Walidacja] Loss: {epoch_val_loss:.4f} | Skuteczność: {epoch_val_acc:.2f}%\")\n",
        "    print(\"-\" * 50)\n",
        "\n",
        "plt.figure(figsize=(12, 5))\n",
        "\n",
        "# Wykres dokładności (Accuracy)\n",
        "plt.subplot(1, 2, 1)\n",
        "plt.plot(range(1, EPOCHS + 1), history['train_acc'], label='Trening (Train)', marker='o')\n",
        "plt.plot(range(1, EPOCHS + 1), history['val_acc'], label='Walidacja (Validation)', marker='s')\n",
        "plt.title('Dokładność modelu (Accuracy)')\n",
        "plt.xlabel('Epoka')\n",
        "plt.ylabel('Skuteczność (%)')\n",
        "plt.grid(True, linestyle='--', alpha=0.5)\n",
        "plt.legend()\n",
        "\n",
        "# Wykres straty (Loss)\n",
        "plt.subplot(1, 2, 2)\n",
        "plt.plot(range(1, EPOCHS + 1), history['train_loss'], label='Trening (Train)', marker='o', color='red')\n",
        "plt.plot(range(1, EPOCHS + 1), history['val_loss'], label='Walidacja (Validation)', marker='s', color='orange')\n",
        "plt.title('Funkcja straty (Loss)')\n",
        "plt.xlabel('Epoka')\n",
        "plt.ylabel('Loss')\n",
        "plt.grid(True, linestyle='--', alpha=0.5)\n",
        "plt.legend()\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "\n",
        "SAVE_PATH = '/content/drive/MyDrive/gtsrb_model_from_scratch1.pth'\n",
        "# Tworzymy folder na Dysku Google, jeśli nie istnieje\n",
        "os.makedirs(os.path.dirname(SAVE_PATH), exist_ok=True)\n",
        "torch.save(model.state_dict(), SAVE_PATH)\n",
        "print(f\"\\n✓ Model został pomyślnie zapisany w: {SAVE_PATH}\")"
      ],
